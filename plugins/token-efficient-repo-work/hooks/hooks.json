{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT}/hooks/session-start.py\"",
            "commandWindows": "pwsh -NoProfile -Command \"& (Join-Path $env:PLUGIN_ROOT 'hooks/session-start.ps1')\"",
            "timeout": 15,
            "statusMessage": "Loading token-safe repository context"
          }
        ]
      }
    ]
  }
}
