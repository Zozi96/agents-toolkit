{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.agents/hooks/session-start.py",
            "commandWindows": "pwsh -NoProfile -Command \"& (Join-Path $HOME '.agents/hooks/session-start.ps1')\"",
            "timeout": 15,
            "statusMessage": "Loading token-safe repository context"
          }
        ]
      }
    ]
  }
}
